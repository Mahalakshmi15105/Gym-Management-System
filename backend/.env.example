# Flask configuration
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your_super_secret_session_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here

# Database configuration
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<db_name>
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/gym_db
